  "supplierFavoredBrands": {
    "_readme": "Brand-substring match (case-insensitive) -- every matching SKU, any size, gets BOTH strategicSupplierPriority:true (scoring boost + wins the anchor/prime-position tiebreak in its section, see anchorPlacement.js) AND alwaysInclude:true (always places regardless of score). Not a UPC list so future new sizes/sub-lines of the same brand are covered automatically.",
    "brandContains": [
      {
        "match": "COPPOLA DIAMOND",
        "reason": "Andrew, 2026-07-23: reverses the 2026-07-12 BUSINESS_RULES.md decision that had excluded Coppola from Strategic Supplier Priority -- explicit new instruction to favor all Francis Coppola Diamond Collection SKUs (Diamond Collection, Diamond Collection Black Label, Diamond Collection Paso Robles), every size, in every store. docs/BUSINESS_RULES.md updated to match."
      }
    ]
  },

  "varietalOverrides": {
    "_readme": "Forces sku.varietal for every SKU whose brand contains 'match' (case-insensitive substring, not exact) -- only affects 750mL SKUs, since that's the only size sectionForSku keys off varietal instead of bottleSizeRaw. Brand-substring match (not a UPC list) so future new flavors of the same line get corrected automatically without needing to know their UPC in advance.",
    "brandContains": [
      {
        "match": "STELLA ROSA",
        "varietal": "FLAVORED/SWEET",
        "reason": "Andrew, 2026-07-23: Il Conte Stella Rosa is a sweet/flavored line despite being from Italy -- raw data mostly labels it varietal ITALY or SPARKLING (routing into the Sparkling Wine section), neither of which is right for the whole brand. All SKUs, all sub-lines (Il Conte, plain Stella Rosa, Organic, Assorted)."
      }
    ]
  }
